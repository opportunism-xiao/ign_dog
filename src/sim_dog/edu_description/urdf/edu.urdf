  <link
    name="RL_FOOT_LINK">
    <inertial>
      <origin
        xyz="-0.0045073 0 -0.00867028"
        rpy="0 0 0" />
      <mass
        value="0.063194610" />
      <inertia
        ixx="0.000020429232"
        ixy="-0.0000000026626"
        ixz="0.0000018517964"
        iyy="0.000021658445"
        iyz="-0.0000000012479232"
        izz="0.000023037914" />
    </inertial>
    <visual>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <geometry>
        <mesh
          filename="package://edu_description/meshes/RL_FOOT_LINK.STL" />
      </geometry>
      <material
        name="">
        <color
          rgba="0.75294 0.75294 0.75294 1" />
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <sphere radius="0.02"/> <!-- 半径按你的脚实际大小微调 -->
        </geometry>
    </collision>
  </link>
  <joint
    name="RL_FOOT_JOINT"
    type="fixed">
    <origin
      xyz="0 0 -0.21366"
      rpy="0 0 0" />
    <parent
      link="RL_KNEE_LINK" />
    <child
      link="RL_FOOT_LINK" />
    <axis
      xyz="0 0 0" />
  </joint>

  <!-- front_camera -->
  <link
    name="front_camera">
  </link>

  <joint
    name="front_camera_joint"
    type="fixed">
    <origin
      xyz="0.26470 0 0.02038"
      rpy="0 0 0" />
    <parent
      link="base_link" />
    <child
      link="front_camera" />
  </joint>


  <!-- 雷达link -->
  <link
    name="laser">
    <inertial>
      <origin
        xyz="-2.91351228429805E-07 0.00125563302353481 1.079127794333E-05"
        rpy="0 0 0" />
      <mass
        value="0.125547937345628" />
      <inertia
        ixx="4.95998226775308E-05"
        ixy="-4.86258968552596E-10"
        ixz="-8.31050558306801E-10"
        iyy="5.59915543947166E-05"
        iyz="1.40519678816194E-09"
        izz="4.97425731410219E-05" />
    </inertial>
    <visual>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <geometry>
        <mesh
          filename="package://edu_description/meshes/laser.STL" />
      </geometry>
      <material
        name="">
        <color
          rgba="1 1 1 1" />
      </material>
    </visual>
    <!-- <collision>
      <origin
        xyz="0 0 0"
        rpy="0 0 0" />
      <geometry>
        <mesh
          filename="package://edu_description/meshes/laser.STL" />
      </geometry>
    </collision> -->
  </link>
  <joint
    name="laser_joint"
    type="fixed">
    <origin
      xyz="0.21 0 0.1"
      rpy="0 0.2618 0" />
    <parent
      link="base_link" />
    <child
      link="laser" />
    <axis
      xyz="0 0 0" />
  </joint>

  <link name="laser_up">
  </link>

  <joint name="laser_up_joint" type="fixed">
    <origin xyz="0.0 0.0 0.1" rpy="0.0 0.0 0.0"/>
    <parent link="base_link"/>
    <child link="laser_up"/>
    <axis xyz="0.0 0.0 0.0"/>
    <limit lower="0.0" upper="0.0" effort="0.0" velocity="0.0"/>
  </joint>

  <!-- 控制机器人运动 -->
  <!-- 运动插件1 生成joint_state_publisher 的插件 关节状态发布节点 -->
   <gazebo>
    <plugin filename="ignition-gazebo-joint-state-publisher-system"
      name="ignition::gazebo::systems::JointStatePublisher">
    </plugin>
  </gazebo>
  <!-- 真实里程计发布（Ignition -->
  <gazebo>
    <plugin filename="ignition-gazebo-odometry-publisher-system"
            name="ignition::gazebo::systems::OdometryPublisher">
      <dimensions>3</dimensions> <!-- 四足有起伏，用 3D -->
    </plugin>
  </gazebo>
  <!-- 运动插件2 生成运动控制器的插件 -->
  
  <!-- 添加传感器插件 -->
  <gazebo>
    <plugin
      filename="ignition-gazebo-sensors-system"
      name="ignition::gazebo::systems::Sensors">
      <render_engine>ogre2</render_engine> <!-- 渲染方式 -->
    </plugin>
  </gazebo>
  <!-- 雷达传感器 -->
  <gazebo reference="laser_up"> <!-- 针对生效的link -->
    <sensor name='scan' type='gpu_lidar'>
      <topic>scan</topic> <!-- 单线 /scan 多线 /scan/points -->
      <update_rate>10</update_rate>
      <pose>0 0 0 0 0 0</pose> <!-- 位置姿态 -->
      
      <lidar>
        <scan>
          <!-- 水平采样参数 -->
          <horizontal>
            <samples>640</samples> <!-- 水平旋转一个周期采样点 默认640 -->
            <resolution>1</resolution> <!-- 雷达分辨率,前后扫描的间隔  单位 度-->
            <!-- 扫描角度 单位 弧度 -->
            <min_angle>-3.1415926</min_angle> <!-- 最小角度 -->
            <max_angle>3.1415926</max_angle> <!-- 最大角度 -->
          </horizontal>
          <!-- 垂直采样参数 -->
          <vertical>
            <samples>32</samples> <!-- 16 线 激光雷达 -->
            <resolution>1</resolution> 
            <min_angle>-0.261799</min_angle>
            <max_angle>0.4</max_angle>
            <!-- <max_angle>0.261799</max_angle> -->
          </vertical>
        </scan>
        <range> <!-- 有效距离 -->
          <min>0.08</min>
          <max>20.0</max>
          <resolution>0.01</resolution> <!-- 扫描精度 米 -->
        </range>
      </lidar>
      <alwaysOn>1</alwaysOn> <!-- 是否一直打开 -->
      <visualize>true</visualize> <!-- 是否可见 -->
      <ignition_frame_id>laser_up</ignition_frame_id> <!-- 指定雷达消息使用的frame-id -->
    </sensor>
  </gazebo>

  <gazebo reference="front_camera">
    <sensor name="depth_camera" type="depth_camera">
          <ignition_frame_id>front_camera</ignition_frame_id>
          <update_rate>10</update_rate>
          <topic>/depth_camera</topic>
          <camera>
            <horizontal_fov>1.05</horizontal_fov>
            <image>
              <width>256</width>
              <height>256</height>
              <format>R_FLOAT32</format>
            </image>
            <clip>
              <near>0.1</near>
              <far>10.0</far>
            </clip>
          </camera>
          <alwaysOn>1</alwaysOn>
      </sensor>
  </gazebo>

  <gazebo reference="front_camera"> 
    <sensor name="camera_link" type="camera">
          <camera>
            <horizontal_fov>1.047</horizontal_fov>
            <image>
              <width>320</width>
              <height>240</height>
              <format>R8G8B8</format>
            </image>
            <clip>
              <near>0.1</near>
              <far>100</far>
            </clip>
          </camera>
          <always_on>true</always_on>
          <update_rate>20</update_rate>
          <visualize>true</visualize>
          <topic>/image_raw</topic>
          <ignition_frame_id>front_camera</ignition_frame_id>
        </sensor>
  </gazebo>

  <gazebo>
  <!-- ROS2 Control bridge for Gazebo Sim (gz) -->
  <plugin filename="gz_ros2_control-system"
          name="gz_ros2_control::GazeboSimROS2ControlPlugin">
    <!-- The plugin will read controller params from this YAML file -->
    <!-- Where to find the robot_description parameter -->
    <parameters>$(find sim_ign_dog)/config/d1_controllers.yaml</parameters>
    <robot_param>robot_description</robot_param>
    <robot_param_node>robot_state_publisher</robot_param_node>
  </plugin>
</gazebo>

  <ros2_control name="GazeboSimSystem" type="system">
  <hardware>
    <plugin>gz_ros2_control/GazeboSimSystem</plugin>
  </hardware>

  <joint name="FL_ABAD_JOINT">
    <command_interface name="position"/>
    <state_interface name="position"/>
    <state_interface name="velocity"/>
  </joint>

  <joint name="FL_HIP_JOINT">
    <command_interface name="position"/>
    <state_interface name="position"/>
    <state_interface name="velocity"/>
  </joint>

  <joint name="FL_KNEE_JOINT">
    <command_interface name="position"/>
    <state_interface name="position"/>
    <state_interface name="velocity"/>
  </joint>

  <joint name="FR_ABAD_JOINT">
    <command_interface name="position"/>
    <state_interface name="position"/>
    <state_interface name="velocity"/>
  </joint>

  <joint name="FR_HIP_JOINT">
    <command_interface name="position"/>
    <state_interface name="position"/>
    <state_interface name="velocity"/>
  </joint>

  <joint name="FR_KNEE_JOINT">
    <command_interface name="position"/>
    <state_interface name="position"/>
    <state_interface name="velocity"/>
  </joint>

  <joint name="RL_ABAD_JOINT">
    <command_interface name="position"/>
    <state_interface name="position"/>
    <state_interface name="velocity"/>
  </joint>

  <joint name="RL_HIP_JOINT">
    <command_interface name="position"/>
    <state_interface name="position"/>
    <state_interface name="velocity"/>
  </joint>

  <joint name="RL_KNEE_JOINT">
    <command_interface name="position"/>
    <state_interface name="position"/>
    <state_interface name="velocity"/>
  </joint>

  <joint name="RR_ABAD_JOINT">
    <command_interface name="position"/>
    <state_interface name="position"/>
    <state_interface name="velocity"/>
  </joint>

  <joint name="RR_HIP_JOINT">
    <command_interface name="position"/>
    <state_interface name="position"/>
    <state_interface name="velocity"/>
  </joint>

  <joint name="RR_KNEE_JOINT">
    <command_interface name="position"/>
    <state_interface name="position"/>
    <state_interface name="velocity"/>
  </joint>
</ros2_control>

</robot>
